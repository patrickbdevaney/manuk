# Secrets — never commit API keys.
.env
.env.*
!.env.example

# Rust build artifacts.
/target
**/*.rs.bk

# Local-only agent tooling. Not part of the shipped engine.

# Local render/debug output.
/*.png
!docs/*.png

mozjs/

firefox/

chromium/

webkit/

WebKit/

stylo/

servo/

taffy/

blitz/

parley/

v8/

ladybird/
# Deep-research provenance for docs/loop/METHODOLOGY.md — local working notes.
METHODOLOGY_RESEARCH.MD


# SPA corpus: the framework SOURCE (build.sh + package manifests) is versioned; node_modules and the
# built dist/ are not. A 300MB node_modules in git is not a corpus, it is a mistake.
tests/spa/apps/*/node_modules/
tests/spa/apps/*/dist/

# ── LOCAL-ONLY TOOLING (never committed) ────────────────────────────────────────────────────────
# Credentials, and development harnesses that depend on a personal environment. A committed tool must
# be runnable by anyone who clones this repository; one that is not, is a local tool by definition.
# Repo-specific local paths live in .git/info/exclude, which is not itself committed — an ignore file
# that NAMES a local tool is a public file describing a private one.
.env
.env.*
!.env.example
**/*.local.*
**/*-LOCAL.md
scripts/local-*
*_RESEARCH.MD
*_RESULT.MD

# Local development harnesses and any credential material. These are working tools, not project
# artifacts: they depend on a personal environment that no clone of this repository has, so
# committing them would only ship something nobody else can run.
.env
.env.*
!.env.example
agent/src/bin/*-local.rs
scripts/local-*
**/*.local.*
METHODOLOGY_RESEARCH.MD

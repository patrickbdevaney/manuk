# Copy to .env (which is gitignored) and fill in your key(s).
#
# The committed runner (`agent-run`) uses a single key:
GROQ_API_KEY=your-groq-api-key-here

# Optional: override the model (default: qwen/qwen3.6-27b, multimodal on Groq).
# GROQ_MODEL=qwen/qwen3.6-27b

# numbered keys to spread rate limits. Add as many as you have:
